# Copy to /etc/edge-scanner/edge-scanner.env and adjust values.

ODDS_API_KEY=
# Or use a pool:
# ODDS_API_KEYS=key_one,key_two

SCAN_CUSTOM_PROVIDERS_ONLY=1
SERVER_AUTO_SCAN_RUN_ON_START=1
SERVER_AUTO_SCAN_INTERVAL_MINUTES=60
SERVER_AUTO_SCAN_CONFIG_PATH=/srv/edge-scanner/shared/server_auto_scan_config.json
SERVER_AUTO_SCAN_LEASE_PATH=/srv/edge-scanner/shared/server_auto_scan.lock

SCAN_SAVE_ENABLED=0
SCAN_REQUEST_LOG_ENABLED=0
SCAN_REQUEST_LOG_RETENTION_FILES=20
HISTORY_MAX_RECORDS=10000

CUSTOM_PROVIDER_SNAPSHOT_DIR=/srv/edge-scanner/shared/provider_snapshots
SCAN_SAVE_DIR=/srv/edge-scanner/shared/scans
HISTORY_DIR=/srv/edge-scanner/shared/history
