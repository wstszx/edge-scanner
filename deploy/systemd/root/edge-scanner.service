[Unit]
Description=Edge Scanner web service (root layout)
After=network.target

[Service]
Type=simple
User=root
Group=root
WorkingDirectory=/root/edge-scanner
EnvironmentFile=-/root/edge-scanner/.env
Environment=SERVER_AUTO_SCAN_ENABLED=0
ExecStart=/root/edge-scanner/venv/bin/gunicorn -w 2 --threads 8 -b 127.0.0.1:5000 wsgi:app
Restart=always
RestartSec=5
TimeoutStopSec=20
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
